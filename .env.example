# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# DATABASE_URL is consumed in two places:
#   - the Next.js app at runtime, via src/env.ts (validated with Zod)
#   - the Prisma CLI for migrate/generate, via prisma.config.ts (loaded by dotenv)
#
# Local development uses a dedicated, least-privilege PostgreSQL role
# (`seapolerp_app`) that owns the `seapolerp` database — the app never connects
# as the postgres superuser.
DATABASE_URL="postgresql://seapolerp_app:CHANGE_ME@localhost:5432/seapolerp?schema=public"

# Better Auth — authentication. Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="CHANGE_ME_generate_a_32_byte_base64_secret"
BETTER_AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Railway (production / client testing) — set these as service Variables, not in
# a committed file. See docs/deployment-railway.md for the full runbook.
#   DATABASE_URL       = ${{Postgres.DATABASE_URL}}   # reference the Postgres plugin
#   BETTER_AUTH_SECRET = <a 32-byte base64 secret, generated as above>
#   BETTER_AUTH_URL    = https://<your-app>.up.railway.app   # the generated public domain
#   HUSKY              = 0                              # skip git hooks during the CI install
# (NODE_ENV is set to "production" automatically by Railway/Nixpacks.)
# ---------------------------------------------------------------------------
