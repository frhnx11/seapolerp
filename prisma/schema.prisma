// SeaPole TMS — Prisma schema.
// Docs: https://pris.ly/d/prisma-schema
//
// Prisma 7: the runtime client is "Rust-free" and uses the query compiler with a
// JS driver adapter (see src/lib/prisma.ts). The connection URL for CLI commands
// (migrate/generate) is configured in prisma.config.ts, not in the datasource block.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Liveness-probe table used by `GET /api/health` to verify end-to-end database
/// connectivity. This is a placeholder and will be removed once the real TMS
/// domain model is defined.

model HealthCheck {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  @@map("health_checks")
}

/// Truck master — the fleet that delivery work orders draw from.
/// Validity dates are stored as "YYYY-MM-DD" strings (timezone-safe and
/// lexically chronological, so expiry checks are simple comparisons).
model Truck {
  id                String   @id @default(cuid())
  vehicleNo         String   @unique @map("vehicle_no")
  wheels            Int // 10 | 12 | 14 | 16
  ownerId           String   @map("owner_id")
  rcValidity        String   @map("rc_validity")
  insuranceValidity String   @map("insurance_validity")
  fcValidity        String   @map("fc_validity")
  status            String   @default("ACTIVE") // ACTIVE | BLOCKED
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  owner       TruckOwner    @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  allotment   AllottedTruck?
  truckOrders TruckOrder[]

  @@index([ownerId])
  @@map("trucks")
}

/// Truck-owner companies — invoices pay one owner for a set of settled trips,
/// so the name must be consistent across the fleet (no free-text owners).
model TruckOwner {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  trucks    Truck[]

  @@map("truck_owners")
}

/// Simple name-only master lists managed from Admin → Master Data.
model CargoType {
  id            String         @id @default(cuid())
  name          String         @unique
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  workOrders     WorkOrder[]
  billsOfLading  BillOfLading[]
  billsOfEntry   BillOfEntry[]
  deliveryOrders DeliveryOrder[]

  @@map("cargo_types")
}

model Party {
  id         String      @id @default(cuid())
  name       String      @unique
  /// Transport rate in ₹ per MT — multiplied with a trip's lowest net weight on
  /// invoices. Snapshotted onto each invoice at creation; null until the admin
  /// sets it (invoice creation is blocked while unset).
  rate          Decimal?       @db.Decimal(12, 2)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  workOrders     WorkOrder[]
  // Delivery-order receivers (per-DO, independent of the vessel's importer).
  deliveryOrders DeliveryOrder[]

  @@map("parties")
}

/// Importer — the company that imports a vessel's cargo. The delivery-order flow
/// (BL/BE/DO) references this, NOT the work-order `Party`. Name-only master.
model Importer {
  id             String          @id @default(cuid())
  name           String          @unique
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  billsOfLading  BillOfLading[]
  billsOfEntry   BillOfEntry[]
  deliveryOrders DeliveryOrder[]

  @@map("importers")
}

model Supplier {
  id         String      @id @default(cuid())
  name       String      @unique
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  workOrders WorkOrder[]

  @@map("suppliers")
}

/// Discount parties — who transport invoices are billed to (replacing the truck
/// owner). Name-only master for now; the invoice link is added in a later step.
model DiscountParty {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  invoices  Invoice[]

  @@map("discount_parties")
}

/// Loading sites at the port (W/H, W/F, C.BELT, …) — where trucks load.
model LoadingSite {
  id        String        @id @default(cuid())
  name      String        @unique
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  truckOrders TruckOrder[]

  @@map("loading_sites")
}

/// Vessel (ship arrival) master — carries the total quantity of goods in the
/// ship. Work orders allocate WO quantities against it; the sum of a vessel's WO
/// quantities can never exceed its total. Each new arrival/consignment is a new
/// vessel row. `seq` renders as "VSL-#001".
model Vessel {
  id            String      @id @default(cuid())
  seq           Int         @unique @default(autoincrement())
  name          String      @unique
  totalQuantity Decimal     @map("total_quantity") @db.Decimal(12, 3)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  workOrders    WorkOrder[]

  @@map("vessels")
}

/// Delivery-Order flow vessel — fully separate from the work-order `Vessel`
/// above. The DO flow never shares rows with the work-order flow; this is the
/// root of its Bill of Lading → Bill of Entry → Delivery Order chain. `seq`
/// renders as "DV-#001".
model DoVessel {
  id            String         @id @default(cuid())
  seq           Int            @unique @default(autoincrement())
  name          String         @unique
  totalQuantity Decimal        @map("total_quantity") @db.Decimal(12, 3)
  depth         Decimal        @db.Decimal(8, 3)
  hatch         Decimal        @db.Decimal(8, 3)
  /// When the vessel arrived at port (shown on the Cargo Delivery Report header).
  arrivalDate   DateTime?      @map("arrival_date")
  createdByName String?        @map("created_by_name")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  billsOfLading  BillOfLading[]
  billsOfEntry   BillOfEntry[]
  deliveryOrders DeliveryOrder[]

  @@map("do_vessels")
}

/// A bill of lading issued against a `DoVessel`. Σ of a vessel's BL quantities
/// can't exceed its total. Parent of the Bill of Entry → Delivery Order chain.
model BillOfLading {
  id            String   @id @default(cuid())
  seq           Int      @unique @default(autoincrement())
  blNumber      Int      @map("bl_number")
  vesselId      String   @map("vessel_id")
  importerId    String   @map("importer_id")
  cargoTypeId   String   @map("cargo_type_id")
  blQuantity    Decimal  @map("bl_quantity") @db.Decimal(12, 3)
  billOfEntryId String?  @map("bill_of_entry_id")
  createdByName String?  @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  vessel      DoVessel     @relation(fields: [vesselId], references: [id], onDelete: Restrict)
  importer    Importer     @relation(fields: [importerId], references: [id], onDelete: Restrict)
  cargoType   CargoType    @relation(fields: [cargoTypeId], references: [id], onDelete: Restrict)
  billOfEntry BillOfEntry? @relation(fields: [billOfEntryId], references: [id], onDelete: SetNull)

  // BL numbers are unique within a vessel (they may repeat across vessels).
  @@unique([vesselId, blNumber])
  @@index([vesselId])
  @@index([importerId])
  @@index([cargoTypeId])
  @@index([billOfEntryId])
  @@map("bills_of_lading")
}

/// A bill of entry groups one or more whole BLs that share the same vessel,
/// importer and cargo type. Each BL belongs to at most one BE; BE quantity is the
/// sum of its BLs (computed, not stored). Parent of the Delivery Order layer.
model BillOfEntry {
  id            String   @id @default(cuid())
  seq           Int      @unique @default(autoincrement())
  beNumber      Int      @map("be_number")
  vesselId      String   @map("vessel_id")
  importerId    String   @map("importer_id")
  cargoTypeId   String   @map("cargo_type_id")
  createdByName String?  @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  vessel        DoVessel       @relation(fields: [vesselId], references: [id], onDelete: Restrict)
  importer      Importer       @relation(fields: [importerId], references: [id], onDelete: Restrict)
  cargoType     CargoType      @relation(fields: [cargoTypeId], references: [id], onDelete: Restrict)
  billsOfLading BillOfLading[]

  // BE numbers are unique within a vessel (they may repeat across vessels).
  @@unique([vesselId, beNumber])
  @@index([vesselId])
  @@index([importerId])
  @@index([cargoTypeId])
  @@map("bills_of_entry")
}

/// A delivery order against a (vessel, importer, cargo type) combo. Σ of a combo's
/// DO quantities can't exceed that combo's total bill-of-entry quantity. `seq`
/// is auto-assigned and rendered "DO-#001". `party` is the receiver — per-DO and
/// independent of the combo (any party can be chosen for any delivery order).
model DeliveryOrder {
  id            String   @id @default(cuid())
  seq           Int      @unique @default(autoincrement())
  vesselId      String   @map("vessel_id")
  importerId    String   @map("importer_id")
  cargoTypeId   String   @map("cargo_type_id")
  partyId       String   @map("party_id")
  doQuantity    Decimal  @map("do_quantity") @db.Decimal(12, 3)
  delivered     Decimal  @default(0) @db.Decimal(12, 3)
  createdByName String?  @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  vessel      DoVessel       @relation(fields: [vesselId], references: [id], onDelete: Restrict)
  importer    Importer       @relation(fields: [importerId], references: [id], onDelete: Restrict)
  cargoType   CargoType      @relation(fields: [cargoTypeId], references: [id], onDelete: Restrict)
  party       Party          @relation(fields: [partyId], references: [id], onDelete: Restrict)
  truckOrders DoTruckOrder[]

  @@index([vesselId])
  @@index([importerId])
  @@index([cargoTypeId])
  @@index([partyId])
  @@map("delivery_orders")
}

/// Delivery-Order flow truck registry — separate from the work-order `Truck`
/// master. Holds just the vehicle number (created on the spot from the Truck DO
/// popup; unique). Mirrors how `DoVessel` is separate from `Vessel`.
model DoTruck {
  id            String         @id @default(cuid())
  vehicleNo     String         @unique @map("vehicle_no")
  createdByName String?        @map("created_by_name")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  truckOrders   DoTruckOrder[]

  @@map("do_trucks")
}

/// A truck delivering against a specific delivery order. `seq` renders "DTO-#001".
/// Only tare is captured now; later weighing stages (→ DeliveryOrder.delivered)
/// land when the delivery-increment flow is defined.
model DoTruckOrder {
  id              String   @id @default(cuid())
  seq             Int      @unique @default(autoincrement())
  deliveryOrderId String   @map("delivery_order_id")
  truckId         String   @map("truck_id")
  tareWeight      Decimal  @map("tare_weight") @db.Decimal(12, 3)
  grossWeight     Decimal? @map("gross_weight") @db.Decimal(12, 3)
  netWeight       Decimal? @map("net_weight") @db.Decimal(12, 3)
  // Attribution + 30-min edit window. createdByName/createdAt are the tare
  // first-entry anchor; tare/gross each track their latest editor, gross also its
  // immutable first-entry stamp (the window anchor for gross corrections).
  createdByName    String?   @map("created_by_name")
  tareByName       String?   @map("tare_by_name")
  tareAt           DateTime? @map("tare_at")
  grossByName      String?   @map("gross_by_name")
  grossAt          DateTime? @map("gross_at")
  grossFirstByName String?   @map("gross_first_by_name")
  grossFirstAt     DateTime? @map("gross_first_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Restrict)
  truck         DoTruck       @relation(fields: [truckId], references: [id], onDelete: Restrict)

  @@index([deliveryOrderId])
  @@index([truckId])
  @@map("do_truck_orders")
}

/// Work Order — an order to deliver part (or all) of a vessel's goods to a Party
/// using many trucks. `seq` is a DB sequence rendered as "WO-#001". Quantities
/// are in metric tons; `woQuantity` is this order's allocation of the vessel's
/// total (mutable over time, ≥ delivered, and Σ per vessel ≤ total); `delivered`
/// is updated later by the delivery module; balance (WO qty − delivered) is derived.
model WorkOrder {
  id         String   @id @default(cuid())
  seq        Int      @unique @default(autoincrement())
  date        String    @map("wo_date") // "YYYY-MM-DD", entered manually
  vesselId    String    @map("vessel_id")
  cargoTypeId String    @map("cargo_type_id")
  supplierId  String    @map("supplier_id")
  partyId     String    @map("party_id")
  woQuantity  Decimal   @map("wo_quantity") @db.Decimal(12, 3)
  delivered   Decimal   @default(0) @db.Decimal(12, 3)
  /// Name snapshot of the admin who created the order (null on legacy rows).
  createdByName String? @map("created_by_name")

  // Customs/regulatory references (consignment-level, printed on every VT sheet).
  bePermissionNo String? @map("be_permission_no")
  eaIaNo         String? @map("ea_ia_no")
  eaIaDate       String? @map("ea_ia_date") // "YYYY-MM-DD"
  sbBeNo         String? @map("sb_be_no")
  sbBeDate       String? @map("sb_be_date") // "YYYY-MM-DD"
  vessel      Vessel    @relation(fields: [vesselId], references: [id], onDelete: Restrict)
  cargoType   CargoType @relation(fields: [cargoTypeId], references: [id], onDelete: Restrict)
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  party       Party     @relation(fields: [partyId], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  truckOrders TruckOrder[]
  invoices    Invoice[]

  @@index([vesselId])
  @@index([supplierId])
  @@index([partyId])
  @@index([cargoTypeId])
  @@map("work_orders")
}

/// Truck Order — one truck's gate-to-gate trip delivering part of a work order.
/// Advances through a fixed stage sequence; each stage snapshots who did it and
/// when. `seq` renders as "TO-#001". Weights are MT; once gross/net is recorded
/// (order COMPLETED) tare and gross are locked because the net has been added to
/// the work order's delivered quantity.
model TruckOrder {
  id          String     @id @default(cuid())
  seq         Int        @unique @default(autoincrement())
  // Null until the gross stage: a trip is created (tare) before the work order
  // is known, and is mapped to one when the gross weight is recorded.
  workOrderId String?    @map("work_order_id")
  truckId     String     @map("truck_id")
  status      String     @default("TARE_RECORDED") // TARE_RECORDED | LOADING_SLIP_ISSUED | COMPLETED
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  truck       Truck      @relation(fields: [truckId], references: [id], onDelete: Restrict)

  // Stage 1 — weighbridge in (creates the trip)
  tareWeight        Decimal  @map("tare_weight") @db.Decimal(12, 3)
  tareByName        String   @map("tare_by_name")
  tareAt            DateTime @map("tare_at")

  // Stage 2 — cargo loading slip
  loadingSiteId     String?      @map("loading_site_id")
  loadingSite       LoadingSite? @relation(fields: [loadingSiteId], references: [id], onDelete: Restrict)
  loadingSlipByName String?      @map("loading_slip_by_name")
  loadingSlipAt     DateTime?    @map("loading_slip_at")

  // Stage 3 — weighbridge out (net updates WorkOrder.delivered)
  vtNumber        String?   @unique @map("vt_number")
  grossWeight     Decimal?  @map("gross_weight") @db.Decimal(12, 3)
  netWeight       Decimal?  @map("net_weight") @db.Decimal(12, 3)
  completedByName String?   @map("completed_by_name")
  completedAt     DateTime? @map("completed_at")

  // Party weighbridge — net weight received at the destination (after COMPLETED)
  netWeightReceived Decimal?  @map("net_weight_received") @db.Decimal(12, 3)
  netReceivedByName String?   @map("net_received_by_name")
  netReceivedAt     DateTime? @map("net_received_at")

  // Immutable first-entry stamps for the 30-minute editing window: who first
  // recorded each value and when. Set once and never overwritten on edits, so
  // the window measures from first entry while the *By/*At stamps above keep
  // tracking the latest editor. Tare's first-entry time is `createdAt` (it's
  // entered at creation), so only its name needs a column here.
  tareFirstByName        String?   @map("tare_first_by_name")
  loadingSlipFirstByName String?   @map("loading_slip_first_by_name")
  loadingSlipFirstAt     DateTime? @map("loading_slip_first_at")
  grossFirstByName       String?   @map("gross_first_by_name")
  grossFirstAt           DateTime? @map("gross_first_at")
  netReceivedFirstByName String?   @map("net_received_first_by_name")
  netReceivedFirstAt     DateTime? @map("net_received_first_at")

  // Invoicing — a trip lives on at most one invoice; deleting the invoice
  // frees the trip. While set, the received weight is locked (no drift).
  invoiceId String?  @map("invoice_id")
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  notifications Notification[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workOrderId, seq])
  @@index([truckId])
  @@index([loadingSiteId])
  @@index([invoiceId])
  @@map("truck_orders")
}

/// Transport invoice — pays one truck-owner company for a set of settled trips
/// (COMPLETED + net received) of one work order. Amounts are a snapshot: the
/// party's ₹/MT rate is frozen at creation (edits recompute with this stored
/// rate, never the party's current one). `seq` renders as "INV-#001".
model Invoice {
  id          String    @id @default(cuid())
  seq         Int       @unique @default(autoincrement())
  workOrderId String    @map("work_order_id")
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Restrict)

  date String @map("invoice_date") // "YYYY-MM-DD", entered manually
  // The vendor's own invoice reference for this bill: a free-text number (e.g.
  // "5844 & 5847") and its date. Both nullable in the DB for migration safety;
  // required at the app layer (the wizard mandates both) and shown on the bill.
  vendorInvoiceNumber String? @map("vendor_invoice_number")
  vendorInvoiceDate   String? @map("vendor_invoice_date") // "YYYY-MM-DD"
  // Who the invoice is billed to (a discount party from master data). Nullable in
  // the DB for migration safety; required at the app layer (the wizard makes it a
  // mandatory pick). One invoice may mix trips of any truck owner.
  discountPartyId String?        @map("discount_party_id")
  discountParty   DiscountParty? @relation(fields: [discountPartyId], references: [id], onDelete: Restrict)
  rate            Decimal        @db.Decimal(12, 2) // ₹/MT, frozen at creation

  totalQty    Decimal @map("total_qty") @db.Decimal(12, 3) // Σ lowest net weights
  amount      Decimal @db.Decimal(14, 2) // totalQty × rate
  discountPct Decimal @default(0) @map("discount_pct") @db.Decimal(5, 2)
  finalAmount Decimal @map("final_amount") @db.Decimal(14, 2) // amount − discount

  remarks String? // optional free text (e.g. the discount reason), shown on the invoice

  createdByName String   @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  truckOrders TruckOrder[]

  @@index([workOrderId])
  @@index([discountPartyId])
  @@map("invoices")
}

/// A net-weight alert delivered to one admin: one row per admin per flagged trip,
/// created when a trip's net received differs from net sent by > 0.3 MT. Reading
/// it deletes the row, so the bell only ever holds unacknowledged alerts.
model Notification {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  truckOrderId String     @map("truck_order_id")
  truckOrder   TruckOrder @relation(fields: [truckOrderId], references: [id], onDelete: Cascade)
  workOrderSeq Int        @map("work_order_seq") // snapshot for the "WO-#…" label
  vehicleNo    String     @map("vehicle_no")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([truckOrderId, userId])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// Global pool of trucks available to deliver work orders. Allotment is no longer
/// tied to a single work order: a truck in this pool can be used by any work order
/// any number of times. Managed by Admin from the "Allotted Trucks" page; the other
/// portals (Port WB, Party WB, Accountant) see it read-only.
model AllottedTruck {
  id             String   @id @default(cuid())
  truckId        String   @unique @map("truck_id")
  truck          Truck    @relation(fields: [truckId], references: [id], onDelete: Cascade)
  /// Name snapshot of the admin who last allotted this truck.
  allottedByName String?  @map("allotted_by_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("allotted_trucks")
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]

  phone        String?
  dateOfBirth  String?
  contactEmail String?
  rollNo       Int?

  notifications Notification[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
